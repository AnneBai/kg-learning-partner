# =============================================
# 知识图谱学习伙伴 - 环境变量配置
# 根据你的模型提供商，填写对应配置即可
# =============================================

# ---------- 模型提供商选择 ----------
# 可选值：huggingface / openai / litellm
MODEL_PROVIDER=openai

# ---------- 模型 ID ----------
# HuggingFace: Qwen/Qwen3-Next-80B-A3B-Thinking
# Kimi: moonshot-v1-8k / moonshot-v1-32k / moonshot-v1-128k
# OpenAI: gpt-4o / gpt-4o-mini
# 通用自定义: 你的模型 ID
MODEL_ID=moonshot-v1-8k

# ============ 方案 A：HuggingFace ============
# 获取地址：https://huggingface.co/settings/tokens
# HF_TOKEN=your_huggingface_token

# ============ 方案 B：OpenAI 兼容 API (Kimi 等) ============
# 支持：Kimi / OpenAI / OpenRouter / Together / vLLM 等任意兼容服务
OPENAI_API_KEY=xxx
# Kimi Base URL：https://api.moonshot.cn/v1
# OpenAI Base URL：https://api.openai.com/v1（留空即默认）
# OpenRouter Base URL：https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.moonshot.cn/v1

# ============ 方案 C：LiteLLM（100+ 提供商） ============
# LITELLM_API_KEY=your_litellm_or_provider_key
# LITELLM_API_BASE=your_provider_base_url
